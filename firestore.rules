rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can read incidents and alerts (public emergency info)
    match /incidents/{id} {
      allow read: if true;
      allow create: if true;          // Public reporting — anyone can report
      allow update, delete: if false; // Only via Admin SDK / Cloud Functions
    }

    match /alerts/{id} {
      allow read: if true;
      allow write: if false;          // Alerts created server-side only
    }

    match /shelters/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
